{
    "version": "0.2.0",
    // ─────────────────────────────────────────────────────
    //  SETUP — two things you need to configure locally:
    //
    //  Option A (recommended): set environment variables
    //    ARM_TOOLCHAIN_PATH  →  path to your arm-none-eabi bin/ folder
    //                           e.g. C:/ArmGNUToolchain/14.3.rel1/bin
    //    OPENOCD_PATH        →  path to your OpenOCD bin/ folder
    //                           e.g. C:/openocd/bin
    //
    //  Option B: replace ${env:...} below with your full paths directly
    //            (don't commit those changes to git)
    // ─────────────────────────────────────────────────────
    "configurations": [
        {
            "name": "STM32H753ZI Debug",
            "type": "cortex-debug",
            "request": "launch",
            "servertype": "openocd",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/build/Debug/PuzzleSolver_MCU.elf",
            "configFiles": [
                "interface/stlink.cfg",
                "target/stm32h7x.cfg"
            ],
            "serverpath": "${env:OPENOCD_PATH}/openocd",
            "gdbPath": "${env:ARM_TOOLCHAIN_PATH}/arm-none-eabi-gdb",
            "svdFile": "${workspaceFolder}/STM32H753xx.svd",
            "runToEntryPoint": "main",
            "showDevDebugOutput": "none"
        }
    ]
}